# ============================================
# EVOLUTION API - CONFIGURAÇÃO
# ============================================

# URL da sua Evolution API hospedada (Railway, VPS, etc)
# Exemplo: https://evolution-api.up.railway.app
EVOLUTION_URL=https://sua-evolution.up.railway.app

# Chave de API para autenticação
# Encontre em: Configurações da Evolution API
EVOLUTION_API_KEY=sua-chave-api-aqui

# Nome da instância WhatsApp criada na Evolution API
# Exemplo: empresa-principal, bot-vendas, etc
EVOLUTION_INSTANCE=nome-da-instancia
